/** bucket-list.wxss - Twos 2.0 Shared Bucket List **/

@import "../../../assets/fonts/serif-font.wxss";

.container {
  padding: 0;
  background-color: #FDFCF8;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header-section {
  padding: 60rpx 40rpx 40rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0D8C0;
}

.title {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: #B22222;
  font-weight: 700;
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 30rpx;
}

.progress-box {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #8C8C8C;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #F8F7F2;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #B22222;
  border-radius: 4rpx;
  transition: width 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.list-scroll {
  flex: 1;
  padding: 20rpx 40rpx;
  box-sizing: border-box;
}

.bucket-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding-bottom: 200rpx;
}

.bucket-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(178, 34, 34, 0.05);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.01);
  transition: all 0.2s;
}

.bucket-item:active {
  transform: scale(0.98);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #E0D8C0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.bucket-item.completed .checkbox {
  background: #B22222;
  border-color: #B22222;
}

.checkmark {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.item-body {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.item-title {
  font-size: 30rpx;
  color: #2F2F2F;
  transition: all 0.3s;
}

.bucket-item.completed .item-title {
  color: #8C8C8C;
  text-decoration: line-through;
}

.item-time {
  font-size: 18rpx;
  color: #B22222;
  opacity: 0.6;
  margin-top: 4rpx;
}

/* 添加区 */
.add-section {
  position: fixed;
  bottom: 120rpx;
  left: 40rpx;
  right: 40rpx;
  background: #FFFFFF;
  padding: 24rpx 30rpx;
  border-radius: 60rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 100;
  border: 1rpx solid rgba(178, 34, 34, 0.1);
}

.add-input {
  flex: 1;
  font-size: 28rpx;
  color: #2F2F2F;
}

.add-btn {
  width: 70rpx;
  height: 70rpx;
  background: #B22222;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

.footer-seal {
  position: fixed;
  bottom: 40rpx;
  width: 100%;
  text-align: center;
  opacity: 0.4;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 22rpx;
  color: #8C8C8C;
  border: 1rpx solid #E0D8C0;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}
