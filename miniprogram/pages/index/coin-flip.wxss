.container {
  padding: 40rpx;
  background-color: #FAF9F6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.letter-paper {
  width: 90%;
  background-color: #FFFFFF;
  border: 1rpx solid #E0D8C0;
  padding: 60rpx 40rpx;
  box-shadow: 10rpx 10rpx 0 rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 85vh;
}

.paper-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-family: "Noto Serif SC", serif;
  font-size: 36rpx;
  color: #2F2F2F;
  letter-spacing: 4rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
  font-style: italic;
  margin-top: 10rpx;
}

/* Betting Area */
.bet-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
}

.bet-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.bet-options {
  display: flex;
  gap: 60rpx;
  margin-bottom: 20rpx;
}

.bet-btn {
  width: 100rpx !important;
  height: 100rpx !important;
  border-radius: 50%;
  background: transparent;
  border: 1rpx solid #E0D8C0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #666;
  transition: all 0.3s;
}

.bet-btn.active {
  background: #2E4E7E;
  color: #FFFFFF;
  border-color: #2E4E7E;
  box-shadow: 0 4rpx 12rpx rgba(46, 78, 126, 0.2);
}

.bet-status {
  width: 100%;
  display: flex;
  justify-content: space-around;
}

.status-msg {
  font-size: 20rpx;
  color: #AAA;
}

/* Coin 3D Logic */
.coin-container {
  width: 280rpx;
  height: 280rpx;
  perspective: 1000px;
  margin: 40rpx 0;
}

.coin {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 2.5s cubic-bezier(0.1, 0.5, 0.1, 1);
}

.coin-side {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 50%;
  border: 4rpx solid #2F2F2F;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.coin-inner {
  width: 90%;
  height: 90%;
  border: 1rpx solid #2F2F2F;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ink-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx dashed rgba(0,0,0,0.1);
}

.coin-text {
  font-family: "Noto Serif SC", serif;
  font-size: 80rpx;
  color: #2F2F2F;
  font-weight: bold;
}

.head {
  z-index: 2;
  transform: rotateY(0deg);
}

.tail {
  transform: rotateY(180deg);
}

.is-flipping {
  transform: rotateY(calc(var(--flip-count) * 180deg));
}

.show-head { transform: rotateY(0deg); }
.show-tail { transform: rotateY(180deg); }

/* Result Box */
.result-box {
  margin-top: 20rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.5s;
}

.result-box.visible { opacity: 1; }

.result-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.result-text {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #333;
  letter-spacing: 2rpx;
}

.winner-text {
  font-size: 26rpx;
  color: #B22222;
  font-style: italic;
}

/* Action Area */
.action-area {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.flip-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #2F2F2F;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  border: none;
  padding: 0;
  transition: all 0.2s;
}

.flip-btn.disabled {
  background: #E0E0E0;
  box-shadow: none;
}

.flip-btn.reset {
  background: #B22222;
}

.flip-btn:active {
  transform: scale(0.95);
}

.btn-text {
  font-family: "Noto Serif SC", serif;
  font-size: 40rpx;
}

.hint-text {
  font-size: 22rpx;
  color: #AAA;
  font-style: italic;
}

.footer-seal {
  margin-top: 40rpx;
  opacity: 0.3;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 24rpx;
  color: #B22222;
  border: 2rpx solid #B22222;
  padding: 4rpx 12rpx;
  letter-spacing: 4rpx;
}
