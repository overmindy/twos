.container {
  padding: 40rpx;
  background-color: #FAF9F6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.letter-paper {
  width: 90%;
  background-color: #FFFFFF;
  border: 1rpx solid #E0D8C0;
  padding: 60rpx 40rpx;
  box-shadow: 10rpx 10rpx 0 rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 80vh;
}

.paper-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-family: "Noto Serif SC", serif;
  font-size: 36rpx;
  color: #2F2F2F;
  letter-spacing: 4rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
  font-style: italic;
  margin-top: 10rpx;
}

/* Coin 3D Logic */
.coin-container {
  width: 300rpx;
  height: 300rpx;
  perspective: 1000px;
  margin: 60rpx 0;
}

.coin {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 2s cubic-bezier(0.4, 0, 0.2, 1);
}

.coin-side {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 50%;
  border: 4rpx solid #2F2F2F;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.coin-inner {
  width: 90%;
  height: 90%;
  border: 1rpx solid #2F2F2F;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ink-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx dashed rgba(0,0,0,0.1);
}

.coin-text {
  font-family: "Noto Serif SC", serif;
  font-size: 80rpx;
  color: #2F2F2F;
  font-weight: bold;
}

.head {
  z-index: 2;
  transform: rotateY(0deg);
}

.tail {
  transform: rotateY(180deg);
}

/* Animation States */
.is-flipping {
  /* Using a large rotation for flipping effect */
  transform: rotateY(calc(var(--flip-count) * 180deg));
}

.show-head {
  transform: rotateY(0deg);
}

.show-tail {
  transform: rotateY(180deg);
}

/* Result Box */
.result-box {
  margin-top: 40rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.5s;
}

.result-box.visible {
  opacity: 1;
}

.result-text {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #B22222;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* Action Area */
.action-area {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.flip-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #B22222;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4rpx 4rpx 0 rgba(0, 0, 0, 0.2);
  border: none;
  padding: 0;
}

.flip-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 rgba(0, 0, 0, 0.2);
}

.flip-btn[disabled] {
  background: #E0D8C0;
  color: #FFFFFF;
}

.btn-text {
  font-family: "Noto Serif SC", serif;
  font-size: 48rpx;
  font-weight: bold;
}

.hint-text {
  font-size: 20rpx;
  color: #888888;
  font-style: italic;
}

.footer-seal {
  margin-top: 40rpx;
  opacity: 0.3;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 24rpx;
  color: #B22222;
  border: 2rpx solid #B22222;
  padding: 4rpx 12rpx;
  letter-spacing: 4rpx;
}
