<!-- pages/index/peace.wxml - Twos 2.0 Calm Space - Bug Fixed -->
<view class="container peace-room">
  <!-- 冷静蒙层：进入时强制降温 -->
  <view class="cooling-overlay {{countdown <= 0 ? 'fade-out' : ''}}">
    <view class="calm-quote">
      <text>{{calmQuote || '于此案前，且慢动笔。\n让情绪随流而去，只留温柔在心。'}}</text>
    </view>
    <view class="countdown-circle" wx:if="{{countdown > 0}}">{{countdown}}</view>
  </view>

  <view class="header">
    <view class="title">止戈室</view>
  </view>
  
  <scroll-view 
    class="chat-history" 
    scroll-y="{{true}}"
    scroll-into-view="{{lastMessageId}}"
    scroll-with-animation="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <view 
      wx:for="{{chatList}}" 
      wx:key="id" 
      id="msg-{{item.id}}"
      class="message-item {{item.role === 'me' ? 'me' : 'ta'}}"
    >
      <view class="bubble">
        <text class="content">{{item.content}}</text>
      </view>
    </view>
    <!-- 占位底部，确保能滚到底 -->
    <view id="bottom-view" style="height: 100rpx; width: 100%;"></view>
  </scroll-view>

  <view class="input-area">
    <input 
      class="chat-input" 
      placeholder="{{countdown > 0 ? '冷静中...' : '温柔低语...'}}" 
      disabled="{{countdown > 0}}"
      value="{{inputValue}}"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="onSendClick"
      cursor-spacing="40"
    />
    <view class="send-btn-cool" bindtap="onSendClick">止戈</view>
  </view>

  <!-- 装饰性背景波纹 -->
  <view class="wave-bg"></view>
</view>
