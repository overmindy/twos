<view class="container peace-room">
  <view class="header serif-text ink-black">
    <view class="title">语气实验室 · 止戈室</view>
    <view class="clear-btn" bindtap="onClearHistory" title="焚化记录">🔥</view>
  </view>
  
  <scroll-view 
    class="chat-history" 
    scroll-y 
    scroll-into-view="{{lastMessageId}}"
    scroll-with-animation
  >
    <view 
      wx:for="{{chatList}}" 
      wx:key="id" 
      id="msg-{{item.id}}"
      class="message-item {{item.role === 'me' ? 'me' : 'ta'}}"
    >
      <view 
        class="bubble {{item.role === 'me' ? 'vermilion-ink' : 'black-ink'}} {{showDetailMap[item.id] ? 'show-detail' : ''}}"
        bindtap="onMessageTap"
        data-id="{{item.id}}"
      >
        <view class="reasoning-text" wx:if="{{item.reasoning && showDetailMap[item.id]}}">
          <text class="reasoning-content">{{item.reasoning}}</text>
        </view>
        <text class="content serif-text">{{item.content}}</text>
        <view class="timestamp">{{item.time}}</view>
      </view>
    </view>

    <!-- 正在处理中的消息占位 -->
    <view wx:if="{{processingMessage}}" class="message-item me" id="msg-processing">
      <view class="bubble vermilion-ink show-detail">
        <view class="reasoning-text" wx:if="{{processingMessage.reasoning}}">
          <text class="reasoning-content">{{processingMessage.reasoning}}</text>
        </view>
        <text class="content serif-text">{{processingMessage.content}}</text>
        <view wx:if="{{processingMessage.isLoading}}" class="loading-status">
          <text class="loading-breathing">墨迹渐浓...</text>
        </view>
        <view class="timestamp">{{processingMessage.time}}</view>
      </view>
    </view>

    <view id="bottom-view" style="height: 20rpx;"></view>
  </scroll-view>

  <view class="input-area">
    <textarea 
      class="chat-input serif-text" 
      placeholder="于此案前，暂且收刀入鞘..." 
      value="{{inputValue}}"
      bindinput="onInputChange"
      auto-height
      fixed
      cursor-spacing="20"
      show-confirm-bar="{{false}}"
    />
    <button class="send-btn serif-text" bindtap="onSendClick">止戈</button>
  </view>

  <!-- 全局纸张纹理覆盖 -->
  <view class="paper-texture"></view>
</view>
