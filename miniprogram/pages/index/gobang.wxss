.container {
  min-height: 100vh;
  background-color: #FDFCF8; /* 宣纸色 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 60rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.5;
  transition: all 0.3s ease;
}

.player-info.active {
  opacity: 1;
  transform: scale(1.1);
}

.vs {
  font-family: 'Serif', serif;
  font-size: 32rpx;
  color: #8C8C8C;
}

.board-wrapper {
  padding: 20rpx;
  background: #fdfaf2;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  border: 1px solid #e8e4d8;
  border-radius: 8rpx;
}

.board {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  background: #fdfaf2;
}

.grid-lines {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  pointer-events: none;
}

.line {
  position: absolute;
  background: #d4cfc1;
}

.row {
  width: 560rpx;
  height: 1px;
}

.col {
  width: 1px;
  height: 560rpx;
}

.interaction-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 600rpx;
  height: 600rpx;
  display: flex;
  flex-direction: column;
}

.board-row {
  display: flex;
  height: 40rpx;
}

.intersection {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.stone {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-shadow: 1px 1px 3px rgba(0,0,0,0.2);
  z-index: 2;
}

.stone.black {
  background: radial-gradient(circle at 30% 30%, #444, #111);
}

.stone.white {
  background: radial-gradient(circle at 30% 30%, #fff, #ddd);
}

@keyframes ink-spread {
  0% {
    transform: scale(2.5);
    opacity: 0.1;
    filter: blur(4rpx);
  }
  100% {
    transform: scale(1);
    opacity: 1;
    filter: blur(0);
  }
}

.stone.newly-placed {
  animation: ink-spread 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 0 20rpx rgba(0,0,0,0.3);
}

.footer {
  margin-top: 60rpx;
  text-align: center;
  min-height: 100rpx;
}

.turn-msg {
  font-size: 28rpx;
  color: #555;
  font-style: italic;
}

.result-msg {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.winner-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #B22222;
  margin-bottom: 20rpx;
}

.btn-restart {
  background: transparent;
  border: 1px solid #B22222;
  color: #B22222;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 10rpx 40rpx;
  line-height: 1.5;
}

.back-link {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #8C8C8C;
  text-decoration: underline;
}
