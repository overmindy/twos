.container {
  min-height: 100vh;
  background-color: #FDFCF8; /* 宣纸色 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 60rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.5;
  transition: all 0.3s ease;
}

.player-info.active {
  opacity: 1;
  transform: scale(1.1);
}

.vs {
  font-family: 'Serif', serif;
  font-size: 32rpx;
  color: #8C8C8C;
}

.board-wrapper {
  padding: 20rpx;
  background: #fdfaf2;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  border: 1px solid #e8e4d8;
  border-radius: 8rpx;
}

.board {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  background: #fdfaf2;
}

.grid-lines {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  pointer-events: none;
}

.line {
  position: absolute;
  background: #d4cfc1;
}

.row {
  width: 560rpx;
  height: 1px;
}

.col {
  width: 1px;
  height: 560rpx;
}

.interaction-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 600rpx;
  height: 600rpx;
  display: flex;
  flex-direction: column;
}

.board-row {
  display: flex;
  height: 40rpx;
}

.intersection {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.stone {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  box-shadow: 1px 1px 3px rgba(0,0,0,0.2);
  z-index: 2;
}

.stone.black {
  background: radial-gradient(circle at 30% 30%, #444, #111);
}

.stone.white {
  background: radial-gradient(circle at 30% 30%, #fff, #ddd);
}

@keyframes ink-spread {
  0% {
    transform: scale(2.5);
    opacity: 0.1;
    filter: blur(4rpx);
  }
  100% {
    transform: scale(1);
    opacity: 1;
    filter: blur(0);
  }
}

.stone.newly-placed {
  animation: ink-spread 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 0 20rpx rgba(0,0,0,0.3);
}

.footer {
  margin-top: 60rpx;
  text-align: center;
  min-height: 100rpx;
}

.turn-msg {
  font-size: 28rpx;
  color: #555;
  font-style: italic;
}

.result-msg {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.winner-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #B22222;
  margin-bottom: 20rpx;
}

.btn-restart {
  background: transparent;
  border: 1px solid #B22222;
  color: #B22222;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 10rpx 40rpx;
  line-height: 1.5;
}

.back-link {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #8C8C8C;
  text-decoration: underline;
}

/* 准备蒙层 */
.ready-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(253, 252, 248, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4rpx);
}

.ready-content {
  width: 560rpx;
  background: #fff;
  border: 1px solid #e8e4d8;
  border-radius: 12rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.05);
}

.ready-title {
  font-size: 40rpx;
  font-family: 'Serif', serif;
  color: #333;
  margin-bottom: 60rpx;
  letter-spacing: 8rpx;
}

.player-status-list {
  width: 100%;
  margin-bottom: 60rpx;
}

.player-status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #f0eee8;
}

.nickname {
  font-size: 30rpx;
  color: #666;
}

.status-tag {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #f5f3ed;
}

.status-tag.ready {
  color: #fff;
  background: #2E4E7E; /* 黛蓝 */
}

.btn-ready {
  width: 300rpx !important;
  background: #B22222 !important; /* 赭红 */
  color: #fff !important;
  font-size: 32rpx;
  border-radius: 50rpx;
  padding: 20rpx 0;
  font-weight: normal;
  box-shadow: 0 6rpx 20rpx rgba(178, 34, 34, 0.2);
}

.waiting-msg {
  font-size: 28rpx;
  color: #8C8C8C;
  font-style: italic;
}

/* 结算蒙层 */
.settlement-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  backdrop-filter: blur(8rpx);
}

.settlement-card {
  width: 580rpx;
  background: #FDFCF8;
  border: 1px solid #e8e4d8;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  position: relative;
}

.settlement-title {
  font-size: 48rpx;
  font-family: 'Serif', serif;
  color: #333;
  margin-bottom: 60rpx;
  letter-spacing: 12rpx;
  border-bottom: 2rpx solid #333;
  padding-bottom: 10rpx;
}

.winner-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.winner-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.winner-nickname {
  font-size: 44rpx;
  font-weight: bold;
  color: #B22222;
  margin-bottom: 30rpx;
}

.winner-info .stone {
  width: 80rpx;
  height: 80rpx;
  transform: scale(1.5);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.3);
}

.settlement-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.settlement-btns button {
  width: 100% !important;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  font-weight: normal;
}

.btn-primary {
  background: #B22222 !important;
  color: #fff !important;
  box-shadow: 0 6rpx 20rpx rgba(178, 34, 34, 0.2);
}

.btn-secondary {
  background: transparent !important;
  border: 1px solid #8C8C8C !important;
  color: #666 !important;
}

.btn-resign {
  font-size: 24rpx;
  color: #8C8C8C;
  background: transparent;
  border: 1rpx solid #E0D8C0;
  border-radius: 6rpx;
  padding: 4rpx 16rpx;
  margin-left: 20rpx;
  line-height: 1.5;
  display: inline-block;
  vertical-align: middle;
}
.turn-msg {
  display: flex;
  align-items: center;
  justify-content: center;
}
