/** peace.wxss - Twos 2.0 Calm Space - Bug Fixed **/

@import "../../assets/fonts/serif-font.wxss";

.peace-room {
  padding: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #F0F4F2;
  position: relative;
  overflow: hidden;
}

/* 顶部：冷静标题 */
.header {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(240, 244, 242, 0.8);
  backdrop-filter: blur(4rpx);
  z-index: 100;
  flex-shrink: 0;
}

.header .title {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #4A5D5E;
  letter-spacing: 4rpx;
}

/* 冷静蒙层 - 修复 pointer-events 阻挡问题 */
.cooling-overlay {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(74, 93, 94, 0.98);
  z-index: 2000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  transition: all 1s ease-in-out;
  pointer-events: all; /* 倒计时期间拦截所有点击 */
}

.cooling-overlay.fade-out {
  opacity: 0;
  pointer-events: none; /* 消失后必须禁用，否则阻挡下层 */
  visibility: hidden;
}

.calm-quote {
  font-family: "Noto Serif SC", serif;
  color: #FFFFFF;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 60rpx;
  padding: 0 80rpx;
  line-height: 1.8;
  opacity: 0.8;
}

.countdown-circle {
  width: 100rpx;
  height: 100rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #FFFFFF;
  font-size: 36rpx;
}

/* 聊天历史区域 - 修复滚动失效 */
.chat-history {
  flex: 1; /* 撑满剩余空间 */
  width: 100%;
  box-sizing: border-box;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.message-item {
  margin-bottom: 40rpx;
  display: flex;
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.bubble {
  max-width: 80%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.message-item.me { justify-content: flex-end; }
.message-item.me .bubble {
  background: #FFFFFF;
  color: #2F2F2F;
  border-bottom-right-radius: 4rpx;
}

.message-item.ta { justify-content: flex-start; }
.message-item.ta .bubble {
  background: #DEEAE7;
  color: #4A5D5E;
  border-bottom-left-radius: 4rpx;
}

/* 输入区域 - 确保层级在装饰背景之上 */
.input-area {
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-top: 1rpx solid #DEEAE7;
  z-index: 500;
  position: relative;
}

.chat-input {
  flex: 1;
  background: #F8F9FA;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
  height: 80rpx;
}

.send-btn-cool {
  width: 120rpx;
  height: 70rpx;
  background: #4A5D5E;
  color: #FFF;
  border-radius: 35rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  z-index: 501;
}

/* 背景波纹动效 - 降低层级，防止阻挡点击 */
.wave-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 150rpx;
  background: linear-gradient(to top, rgba(74, 93, 94, 0.03), transparent);
  z-index: 1;
  pointer-events: none;
}
