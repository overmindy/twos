<!-- miniprogram/pages/index/games.wxml -->
<view class="container">
  <view class="paper-title-container">
    <text class="page-title">手札游戏</text>
    <view class="title-underline"></view>
  </view>

  <view class="game-bento-grid">
    <!-- 你画我猜 2.0 (Hero size) -->
    <view class="game-bento-item game-large" bindtap="goToDrawGuess">
      <view class="game-icon-large">
        <image class="game-icon-large" src="../../images/icons/quill.png" mode="aspectFit"></image>
      </view>
      <view class="game-info-large">
        <text class="game-name">你画我猜 2.0</text>
        <text class="game-desc">实时轨迹追踪，心有灵犀一点通</text>
      </view>
    </view>

    <!-- 真心话大冒险 (AI版) -->
    <view class="game-bento-item game-medium" bindtap="goToTruthOrDare">
      <view class="game-icon-medium">
        <image class="game-icon-medium" src="../../images/icons/happy.png" mode="aspectFit"></image>
      </view>
      <view class="game-info-medium">
        <text class="game-name">灵魂拷问</text>
        <text class="game-desc">AI 深度定制的大冒险</text>
      </view>
    </view>

    <!-- 默契刮刮乐 -->
    <view class="game-bento-item game-medium" bindtap="goToScratch">
      <view class="game-icon-medium">
        <image class="game-icon-medium" src="../../images/icons/hug.png" mode="aspectFit"></image>
      </view>
      <view class="game-info-medium">
        <text class="game-name">默契刮刮乐</text>
        <text class="game-desc">刮开纸上的秘密奖励</text>
      </view>
    </view>

    <!-- 纸上抛硬币 -->
    <view class="game-bento-item game-medium" bindtap="goToCoinFlip">
      <view class="game-icon-medium">
        <image class="game-icon-medium" src="../../images/icons/hourglass.png" mode="aspectFit"></image>
      </view>
      <view class="game-info-medium">
        <text class="game-name">抛硬币</text>
        <text class="game-desc">听天由命的温柔</text>
      </view>
    </view>

    <!-- 纸上五子棋 -->
    <view class="game-bento-item game-medium" bindtap="goToGobang">
      <view class="game-icon-medium">
        <image class="game-icon-medium" src="../../images/icons/game.png" mode="aspectFit"></image>
      </view>
      <view class="game-info-medium">
        <text class="game-name">五子棋</text>
        <text class="game-desc">落子皆是你</text>
      </view>
    </view>

    <!-- 全网排行榜 -->
    <view class="game-bento-item game-medium" bindtap="goToLeaderboard">
      <view class="game-icon-medium">
        <text style="font-size: 40rpx;">🏆</text>
      </view>
      <view class="game-info-medium">
        <text class="game-name">全网排行</text>
        <text class="game-desc">看看谁的羁绊最深厚</text>
      </view>
    </view>
  </view>

  <!-- 近期战报 -->
  <view class="history-section" wx:if="{{gameHistory.length > 0}}">
    <view class="section-header">
      <text class="section-title">近期战报</text>
      <view class="section-line"></view>
    </view>
    
    <view class="history-list">
      <view class="history-item" wx:for="{{gameHistory}}" wx:key="_id">
        <view class="history-info-top">
          <text class="history-game-name">{{item.gameName}}</text>
          <text class="history-date">{{item.dateStr}}</text>
        </view>
        <view class="history-info-bottom">
          <view class="history-winner">
            <text class="winner-label">胜者:</text>
            <text class="winner-name">{{item.winnerName || '无'}}</text>
          </view>
          <view class="history-duration">
            <text class="duration-label">耗时:</text>
            <text class="duration-time">{{item.durationStr}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部印记 -->
  <view class="footer-seal">
    <text class="seal-text">手札·游乐场</text>
  </view>
</view>