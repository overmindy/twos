<view class="container">
  <!-- 背景艺术：信纸边框或晕染 (可选) -->
  <view class="paper-title-container">
    <text class="page-title">手札游戏</text>
    <view class="title-underline"></view>
  </view>

  <view class="game-list">
    <!-- 纸上抛硬币 -->
    <view class="game-card" bindtap="goToCoinFlip">
      <view class="card-inner">
        <view class="game-icon">
          <image class="game-icon-img" src="../../images/icons/hourglass.png" mode="aspectFit"></image>
        </view>
        <view class="game-info">
          <text class="game-name">纸上抛硬币</text>
          <text class="game-desc">墨色一掷，听天由命的温柔</text>
        </view>
        <view class="arrow-seal">印</view>
      </view>
    </view>

    <!-- 纸上五子棋 -->
    <view class="game-card" bindtap="goToGobang">
      <view class="card-inner">
        <view class="game-icon">
          <image class="game-icon-img" src="../../images/icons/game.png" mode="aspectFit"></image>
        </view>
        <view class="game-info">
          <text class="game-name">纸上五子棋</text>
          <text class="game-desc">横竖经纬间，落子皆是你</text>
        </view>
        <view class="arrow-seal">印</view>
      </view>
    </view>

    <!-- 默契刮刮乐 -->
    <view class="game-card" bindtap="goToScratch">
      <view class="card-inner">
        <view class="game-icon">
          <image class="game-icon-img" src="../../images/icons/quill.png" mode="aspectFit"></image>
        </view>
        <view class="game-info">
          <text class="game-name">默契刮刮乐</text>
          <text class="game-desc">刮开纸上的秘密，同步你们的心跳</text>
        </view>
        <view class="arrow-seal">印</view>
      </view>
    </view>

    <!-- 你画我猜 -->
    <view class="game-card" bindtap="goToDrawGuess">
      <view class="card-inner">
        <view class="game-icon">
          <image class="game-icon-img" src="../../images/icons/voice.png" mode="aspectFit"></image>
        </view>
        <view class="game-info">
          <text class="game-name">你画我猜</text>
          <text class="game-desc">我的笔尖，连着你的直觉</text>
        </view>
        <view class="arrow-seal">印</view>
      </view>
    </view>
  </view>

  <!-- 近期战报 -->
  <view class="history-section" wx:if="{{gameHistory.length > 0}}">
    <view class="section-header">
      <text class="section-title">近期战报</text>
      <view class="section-line"></view>
    </view>
    
    <view class="history-list">
      <view class="history-item" wx:for="{{gameHistory}}" wx:key="_id">
        <view class="history-info-top">
          <text class="history-game-name">{{item.gameName}}</text>
          <text class="history-date">{{item.dateStr}}</text>
        </view>
        <view class="history-info-bottom">
          <view class="history-winner">
            <text class="winner-label">胜者:</text>
            <text class="winner-name">{{item.winner || '无'}}</text>
          </view>
          <view class="history-duration">
            <text class="duration-label">耗时:</text>
            <text class="duration-time">{{item.durationStr}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部印记 -->
  <view class="footer-seal">
    <text class="seal-text">手札·游乐场</text>
  </view>
</view>