.container {
  min-height: 100vh;
  background-color: #FDFCF8;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.paper-title-container {
  margin-top: 20rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.page-title {
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 42rpx;
  color: #2c2c2c;
  letter-spacing: 4rpx;
  font-weight: 300;
}

.title-underline {
  width: 120rpx;
  height: 2rpx;
  background: #d4d4d4;
  margin: 16rpx auto 0;
}

.game-area {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  background: #f0f0f0;
  border: 1rpx solid #e0e0e0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border-radius: 8rpx;
  overflow: hidden;
}

.scratch-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #fff;
}

.secret-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.3s ease;
}

.heart-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.message-text {
  font-size: 32rpx;
  color: #8c8c8c;
  font-family: "Serif", serif;
}

.completion-text {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #b22222;
  font-weight: bold;
}

.scratch-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 600rpx;
  height: 600rpx;
  z-index: 10;
  touch-action: none;
}

.game-info {
  width: 100%;
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-container {
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.progress-label {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 12rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-inner {
  height: 100%;
  background-color: #b22222;
  transition: width 0.3s ease;
}

.progress-value {
  font-size: 24rpx;
  color: #b22222;
  font-weight: 500;
}

.status-tips {
  font-size: 28rpx;
  color: #8c8c8c;
  font-family: "Serif", serif;
  font-style: italic;
  margin-top: 20rpx;
}

.btn-ready {
  background: transparent;
  border: 1rpx solid #b22222;
  color: #b22222;
  font-size: 28rpx;
  padding: 10rpx 40rpx;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.btn-ready.ready {
  background: #b22222;
  color: #fff;
}

.footer-seal {
  margin-top: auto;
  margin-bottom: 40rpx;
  padding: 20rpx 40rpx;
  border: 1rpx solid #d4d4d4;
  opacity: 0.6;
}

.seal-text {
  font-size: 24rpx;
  color: #8c8c8c;
  letter-spacing: 10rpx;
  writing-mode: vertical-rl;
}

/* 心跳动效 */
.heartbeat {
  animation: heartbeat 1.2s infinite;
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  14% { transform: scale(1.1); }
  28% { transform: scale(1); }
  42% { transform: scale(1.1); }
  70% { transform: scale(1); }
}

.game-area.finished {
  box-shadow: 0 0 40rpx rgba(178, 34, 34, 0.2);
  border-color: rgba(178, 34, 34, 0.3);
}
