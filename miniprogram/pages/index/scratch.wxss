/* pages/index/scratch.wxss - Twos 2.0 Bento Style */

@import "../../assets/fonts/serif-font.wxss";

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #FDFCF8;
  box-sizing: border-box;
}

.paper-title-container {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-title {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: #B22222;
  font-weight: 700;
  letter-spacing: 8rpx;
}

.title-underline {
  width: 120rpx;
  height: 4rpx;
  background: #B22222;
  margin-top: 16rpx;
}

/* 游戏区域 - 类似一张拍立得相纸 */
.game-area {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(178, 34, 34, 0.1);
  overflow: hidden;
  border: 2rpx solid rgba(178, 34, 34, 0.05);
  transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.game-area.finished {
  transform: scale(1.05);
  box-shadow: 0 40rpx 80rpx rgba(178, 34, 34, 0.15);
}

/* 底层奖励内容 */
.scratch-content {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: radial-gradient(circle, #FFF9F9 0%, #FDFCF8 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.prize-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 100%;
}

.heartbeat {
  animation: heartPulse 0.8s ease-in-out infinite alternate;
}

@keyframes heartPulse {
  from { transform: scale(1); }
  to { transform: scale(1.15); }
}

.prize-label {
  font-size: 24rpx;
  color: #8C8C8C;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.prize-text {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: #B22222;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
}

.heart-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.message-text {
  font-size: 28rpx;
  color: #8C8C8C;
  font-style: italic;
}

.stamp {
  position: absolute;
  bottom: 40rpx;
  right: 40rpx;
  border: 4rpx solid #B22222;
  color: #B22222;
  font-size: 32rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  transform: rotate(-15deg);
  opacity: 0.8;
  font-family: "Noto Serif SC", serif;
}

/* 表层 Canvas */
.scratch-canvas {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 10;
}

/* 控制面板区 */
.controls-section {
  margin-top: 60rpx;
  width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.prize-setup {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: #FFFFFF;
  padding: 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
  border: 1rpx solid #E0D8C0;
}

.setup-hint {
  font-size: 24rpx;
  color: #8C8C8C;
  text-align: center;
  margin-bottom: 10rpx;
}

.prize-input {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 32rpx;
  text-align: center;
  color: #2F2F2F;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.prize-input:focus {
  border-color: #B22222;
}

.btn-ready {
  background: #B22222 !important;
  color: #FFFFFF !important;
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  padding: 20rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.btn-ready.ready {
  background: #4A5D5E !important; /* 冷静黛青色，表示已锁定 */
  opacity: 0.8;
}

/* 进度条 */
.progress-info {
  background: #FFFFFF;
  padding: 30rpx 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
  border: 1rpx solid #E0D8C0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #F0F4F2;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #E0D8C0, #B22222);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #5C5C5C;
  font-family: monospace;
}

/* 底部返回 */
.footer-seal {
  margin-top: auto;
  margin-bottom: 40rpx;
  padding: 20rpx 60rpx;
  border: 2rpx solid #E0D8C0;
  border-radius: 40rpx;
  transition: all 0.2s;
}

.footer-seal:active {
  background: #F8F9FA;
  transform: scale(0.95);
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 28rpx;
  color: #8C8C8C;
}
