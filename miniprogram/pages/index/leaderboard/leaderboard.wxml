<!-- miniprogram/pages/index/leaderboard/leaderboard.wxml -->
<view class="container">
  <view class="header">
    <text class="title">羁绊排行</text>
    <text class="subtitle">全网最深厚的连接见证</text>
  </view>

  <scroll-view scroll-y class="rank-scroll">
    <view class="rank-list">
      <view class="rank-item {{index < 3 ? 'top-three' : ''}}" wx:for="{{list}}" wx:key="index">
        <view class="rank-num">{{item.rank}}</view>
        <view class="rank-info">
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-stats">🔥 连击 {{item.streak}} · ✨ 能量 {{item.energy}}</text>
        </view>
        <view class="rank-medal" wx:if="{{index === 0}}">👑</view>
        <view class="rank-medal" wx:if="{{index === 1}}">🥈</view>
        <view class="rank-medal" wx:if="{{index === 2}}">🥉</view>
      </view>
    </view>
  </scroll-view>

  <view class="footer-seal" bindtap="goBack">
    <text class="seal-text">返回手札</text>
  </view>
</view>
