/** leaderboard.wxss **/
@import "../../../assets/fonts/serif-font.wxss";

.container {
  padding: 0;
  background-color: #FDFCF8;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0D8C0;
}

.title {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: #B22222;
  font-weight: 700;
  letter-spacing: 8rpx;
}

.subtitle {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 10rpx;
}

.rank-scroll {
  flex: 1;
}

.rank-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid rgba(178, 34, 34, 0.05);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.01);
}

.rank-item.top-three {
  border-color: #D4AF37;
  background: linear-gradient(135deg, #FFFDF5 0%, #FFFFFF 100%);
}

.rank-num {
  width: 60rpx;
  font-size: 36rpx;
  font-family: monospace;
  color: #B22222;
  font-weight: 700;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rank-name {
  font-family: "Noto Serif SC", serif;
  font-size: 30rpx;
  color: #2F2F2F;
  margin-bottom: 6rpx;
}

.rank-stats {
  font-size: 20rpx;
  color: #8C8C8C;
}

.rank-medal {
  font-size: 40rpx;
}

.footer-seal {
  padding: 40rpx;
  text-align: center;
  opacity: 0.4;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 22rpx;
  color: #8C8C8C;
  border: 1rpx solid #E0D8C0;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}
