/* miniprogram/pages/index/games.wxss */
@import "../../assets/fonts/serif-font.wxss";

.container {
  padding: 40rpx;
  background-color: var(--bg-color, #FDFCF8);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.paper-title-container {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-title {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: var(--accent-color, #B22222);
  font-weight: 700;
  letter-spacing: 8rpx;
}

.title-underline {
  width: 120rpx;
  height: 4rpx;
  background: var(--accent-color, #B22222);
  margin-top: 16rpx;
}

/* Bento Grid for Games */
.game-bento-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  width: 100%;
}

.game-bento-item {
  background: var(--card-bg, #FFFFFF);
  border: 1rpx solid var(--border-color, rgba(178, 34, 34, 0.1));
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow-color, rgba(0, 0, 0, 0.02));
  display: flex;
  flex-direction: column;
  position: relative;
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.game-bento-item:active {
  transform: scale(0.96);
}

/* Specific Sizes */
.game-large {
  grid-column: span 4;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(178, 34, 34, 0.05) 0%, var(--card-bg) 100%);
}

.game-medium {
  grid-column: span 2;
  height: 240rpx;
  justify-content: space-between;
}

.game-icon-large {
  width: 100rpx;
  height: 100rpx;
}

.game-info-large {
  flex: 1;
  margin-left: 30rpx;
}

.game-icon-medium {
  width: 60rpx;
  height: 60rpx;
}

.game-name {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main, #2F2F2F);
  margin-bottom: 8rpx;
  display: block;
}

.game-desc {
  font-size: 22rpx;
  color: var(--text-sub, #8C8C8C);
  line-height: 1.4;
}

/* 近期战报 */
.history-section {
  width: 100%;
  margin-top: 80rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.section-title {
  font-family: "Noto Serif SC", serif;
  font-size: 28rpx;
  color: var(--text-sub, #8C8C8C);
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: var(--border-color, #E0D8C0);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: var(--card-bg, #FFFFFF);
  padding: 30rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--border-color, #E0D8C0);
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-game-name {
  font-family: "Noto Serif SC", serif;
  font-size: 28rpx;
  color: var(--text-main, #2F2F2F);
  font-weight: 600;
}

.history-date {
  font-size: 22rpx;
  color: var(--text-sub, #AAAAAA);
}

.history-info-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-winner, .history-duration {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.winner-label, .duration-label {
  font-size: 22rpx;
  color: var(--text-sub, #888888);
}

.winner-name, .duration-time {
  font-size: 24rpx;
  color: var(--accent-color, #B22222);
  font-weight: 600;
}

.footer-seal {
  margin-top: 80rpx;
  padding-bottom: 40rpx;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 24rpx;
  color: var(--text-sub, #8C8C8C);
  letter-spacing: 4rpx;
}
