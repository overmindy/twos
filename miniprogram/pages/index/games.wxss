.container {
  padding: 60rpx 40rpx;
  background-color: #FAF9F6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.paper-title-container {
  margin-top: 40rpx;
  margin-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-title {
  font-family: "Noto Serif SC", serif;
  font-size: 44rpx;
  color: #2F2F2F;
  letter-spacing: 8rpx;
  font-weight: 500;
}

.title-underline {
  width: 120rpx;
  height: 4rpx;
  background: #B22222;
  margin-top: 12rpx;
}

.game-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.game-card {
  width: 100%;
  background: #FFFFFF;
  border: 1rpx solid #E0D8C0;
  box-shadow: 6rpx 6rpx 0 rgba(224, 216, 192, 0.4);
  position: relative;
  transition: all 0.2s;
}

.game-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 4rpx 4rpx 0 rgba(224, 216, 192, 0.4);
}

.game-card.locked {
  opacity: 0.6;
}

.card-inner {
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.game-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-icon-img {
  width: 100%;
  height: 100%;
}

.game-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.game-name {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #2F2F2F;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.game-desc {
  font-size: 24rpx;
  color: #888888;
  font-style: italic;
}

.arrow-seal {
  width: 50rpx;
  height: 50rpx;
  border: 2rpx solid #B22222;
  color: #B22222;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  transform: rotate(15deg);
}

.footer-seal {
  margin-top: 60rpx;
  padding-bottom: 60rpx;
  opacity: 0.3;
}

/* 近期战报样式 */
.history-section {
  width: 100%;
  margin-top: 80rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.section-title {
  font-family: "Noto Serif SC", serif;
  font-size: 28rpx;
  color: #888888;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: #E0D8C0;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: #FFFFFF;
  padding: 30rpx;
  border: 1rpx dashed #E0D8C0;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-game-name {
  font-family: "Noto Serif SC", serif;
  font-size: 28rpx;
  color: #2F2F2F;
  font-weight: 500;
}

.history-date {
  font-size: 22rpx;
  color: #AAAAAA;
}

.history-info-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-winner, .history-duration {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.winner-label, .duration-label {
  font-size: 24rpx;
  color: #888888;
}

.winner-name, .duration-time {
  font-size: 24rpx;
  color: #B22222;
  font-weight: 500;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 24rpx;
  color: #B22222;
  border: 2rpx solid #B22222;
  padding: 4rpx 12rpx;
  letter-spacing: 4rpx;
}
