<view class="container">
  <view class="header">
    <view class="player-info {{currentTurn === 'black' ? 'active' : ''}}">
      <view class="stone black"></view>
      <text>{{blackNickname || '黑方'}}</text>
    </view>
    <view class="vs">对弈</view>
    <view class="player-info {{currentTurn === 'white' ? 'active' : ''}}">
      <view class="stone white"></view>
      <text>{{whiteNickname || '白方'}}</text>
    </view>
  </view>

  <view class="board-wrapper">
    <view class="board">
      <!-- 棋盘线条 -->
      <view class="grid-lines">
        <view wx:for="{{15}}" wx:key="index" class="line row" style="top: {{index * 40 + 20}}rpx;"></view>
        <view wx:for="{{15}}" wx:key="index" class="line col" style="left: {{index * 40 + 20}}rpx;"></view>
      </view>

      <!-- 棋盘交互点 (15x15) -->
      <view class="interaction-layer">
        <view 
          wx:for="{{15}}" 
          wx:for-index="rowIndex" 
          wx:key="rowIndex" 
          class="board-row"
        >
          <view 
            wx:for="{{15}}" 
            wx:for-index="colIndex" 
            wx:key="colIndex" 
            class="intersection"
            bindtap="onTapIntersection"
            data-x="{{rowIndex}}"
            data-y="{{colIndex}}"
          >
            <view wx:if="{{board[rowIndex][colIndex]}}" class="stone {{board[rowIndex][colIndex]}} {{lastMove.x === rowIndex && lastMove.y === colIndex ? 'newly-placed' : ''}}"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="footer">
    <view wx:if="{{gameStatus === 'won'}}" class="result-msg">
      <text class="winner-text">{{winner === 'black' ? (blackNickname || '黑方') : (whiteNickname || '白方')}} 胜出</text>
      <button class="btn-restart" bindtap="restartGame">再弈一局</button>
    </view>
    <view wx:else class="turn-msg">
      <text>{{currentTurn === myColor ? '轮到你了' : '对方思考中...'}}</text>
    </view>
  </view>

  <view class="back-link" bindtap="goBack">返回博弈大厅</view>

  <!-- 准备蒙层 UI -->
  <view wx:if="{{room && room.status !== 'PLAYING'}}" class="ready-mask">
    <view class="ready-content">
      <view class="ready-title">弈前准备</view>
      <view class="player-status-list">
        <view class="player-status-item">
          <text class="nickname">{{blackNickname}}</text>
          <text class="status-tag {{room.players.playerA.ready ? 'ready' : ''}}">
            {{room.players.playerA.ready ? '已就绪' : '思索中...'}}
          </text>
        </view>
        <view class="player-status-item">
          <text class="nickname">{{whiteNickname}}</text>
          <text class="status-tag {{room.players.playerB.ready ? 'ready' : ''}}">
            {{room.players.playerB.ready ? '已就绪' : '思索中...'}}
          </text>
        </view>
      </view>
      
      <button 
        wx:if="{{!isMyReady}}" 
        class="btn-ready" 
        bindtap="handleReady"
      >
        准备就绪
      </button>
      <view wx:else class="waiting-msg">等待对方入局...</view>
    </view>
  </view>

  <view wx:if="{{!room}}" class="ready-mask">
    <view class="ready-content">
      <view class="ready-title">开启对局</view>
      <button class="btn-ready" bindtap="handleReady">准备</button>
    </view>
  </view>
</view>
