/* miniprogram/pages/index/answer.wxss */
.container {
  height: 100vh;
  background: #FDFCF8;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  box-sizing: border-box;
}

.letter-sheet {
  width: 100%;
  height: 100%;
  position: relative;
  box-shadow: 0 4rpx 30rpx rgba(0,0,0,0.05);
}

.paper-bg {
  background: #FEFEF9;
  width: 100%;
  height: 100%;
  border: 1rpx solid #E6E2D3;
  position: relative;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  -webkit-overflow-scrolling: touch;
}

.grid-layer {
  position: absolute;
  top: 0; left: 0; right: 0; 
  height: 200%; /* Make it long enough for scrolling */
  pointer-events: none;
  background-image: 
    linear-gradient(#E6E2D3 1px, transparent 1px),
    linear-gradient(90deg, #E6E2D3 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  opacity: 0.15;
}

.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  min-height: 100%;
  box-sizing: border-box;
}

.date-header {
  font-family: 'Serif', serif;
  font-size: 28rpx;
  color: #8C8C8C;
  text-align: right;
  margin-bottom: 60rpx;
  font-style: italic;
}

.question-section {
  margin-bottom: 40rpx;
}

.question-label {
  font-size: 24rpx;
  color: #B22222;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.question-text {
  font-family: 'Serif', serif;
  font-size: 40rpx;
  color: #2F2F2F;
  line-height: 1.6;
}

.ink-divider {
  height: 2rpx;
  background: #2F2F2F;
  margin: 40rpx 0;
  opacity: 0.08;
}

.input-section {
  position: relative;
  display: flex;
  flex-direction: column;
  padding-bottom: 20rpx;
}

.ink-textarea {
  width: 100%;
  height: 400rpx;
  font-family: 'Serif', serif;
  font-size: 34rpx;
  color: #2F2F2F;
  line-height: 1.8;
  background: transparent;
}

.ink-textarea.voice-note,
.ink-textarea.image-note {
  height: 240rpx;
}

.char-counter {
  font-size: 22rpx;
  color: #8C8C8C;
  text-align: right;
  margin-top: 10rpx;
}

.footer-section {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
  gap: 100rpx; /* 增加两个印章之间的间距 */
}

/* 多模态工具栏 */
.mode-toolbar {
  display: flex;
  margin-bottom: 40rpx;
  gap: 30rpx;
}

.mode-item {
  width: 70rpx;
  height: 70rpx;
  border: 1rpx solid #E6E2D3;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s;
  background: rgba(255, 255, 255, 0.5);
}

.mode-icon-img {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.4;
}

.mode-item.active {
  background: #2F2F2F;
  border-color: #2F2F2F;
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.mode-item.active .mode-icon-img {
  opacity: 1;
  filter: invert(1);
}

.mode-icon {
  font-size: 26rpx;
  color: #8C8C8C;
  font-family: 'Serif', serif;
}

/* 极简语音部分 */
.voice-section {
  display: flex;
  flex-direction: column;
  gap: 60rpx;
  width: 100%;
  align-items: center;
  padding: 40rpx 0;
}

.voice-seal-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.mic-seal {
  width: 200rpx;
  height: 200rpx;
  background: #FEFEF9;
  border: 2rpx solid #E6E2D3;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.03);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.mic-seal-inner {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx solid #B22222;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.mic-seal-inner::after {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border: 1rpx solid #B22222;
  border-radius: 50%;
  opacity: 0.2;
}

.mic-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.8;
}

.mic-seal.has-voice {
  background: rgba(178, 34, 34, 0.03);
  border-color: rgba(178, 34, 34, 0.2);
}

.mic-seal.has-voice .mic-icon {
  opacity: 1;
}

.mic-seal.pulse {
  transform: scale(1.1);
  box-shadow: 0 0 40rpx rgba(178, 34, 34, 0.2);
  animation: seal-pulse 1.5s infinite ease-in-out;
}

@keyframes seal-pulse {
  0% { transform: scale(1.1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1.1); }
}

.mic-seal:active {
  transform: scale(0.95);
}

.voice-hint {
  font-size: 24rpx;
  color: #8C8C8C;
  letter-spacing: 2rpx;
}

.voice-action-mini {
  font-size: 22rpx;
  color: #B22222;
  border-bottom: 1rpx solid rgba(178, 34, 34, 0.3);
  padding-bottom: 4rpx;
  margin-top: 10rpx;
}

/* 录制中全屏蒙层与动态声波 */
.recording-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(253, 252, 248, 0.9);
  backdrop-filter: blur(10rpx);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 100rpx;
}

.dynamic-waves-full {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 200rpx;
  width: 80%;
}

.wave-item {
  width: 8rpx;
  background: #B22222;
  border-radius: 4rpx;
  animation: wave-grow 0.8s infinite ease-in-out;
}

@keyframes wave-grow {
  0%, 100% { transform: scaleY(0.3); opacity: 0.3; }
  50% { transform: scaleY(1); opacity: 0.8; }
}

.recording-stop-seal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.stop-seal-inner {
  width: 140rpx;
  height: 140rpx;
  border: 6rpx solid #B22222;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.stop-text {
  font-family: 'Serif', serif;
  font-size: 60rpx;
  color: #B22222;
  font-weight: bold;
}

.stop-hint {
  font-size: 26rpx;
  color: #B22222;
  letter-spacing: 4rpx;
  font-weight: bold;
}


.image-delete {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 50rpx;
  height: 50rpx;
  background: #B22222;
  color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2);
}

/* 图片部分 - 拍立得 */
.image-section {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  width: 100%;
  align-items: center;
}

.polaroid-frame {
  width: 440rpx;
  background: #FFFFFF;
  padding: 24rpx 24rpx 100rpx 24rpx;
  box-shadow: 0 15rpx 40rpx rgba(0,0,0,0.06);
  border: 1rpx solid #E6E2D3;
  transform: rotate(-1.5deg);
  margin: 20rpx 0;
  transition: all 0.3s;
}

.polaroid-frame:active {
  transform: rotate(0) scale(1.02);
}

.polaroid-img {
  width: 100%;
  height: 400rpx;
  background: #F9F9F9;
  display: block;
}

.polaroid-placeholder {
  width: 100%;
  height: 400rpx;
  background: #FDFDFD;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: #D0D0D0;
  border: 1rpx solid #F0F0F0;
}

/* 已作答状态印章 */
.answered-seal-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.privacy-toggle {
  font-size: 22rpx;
  color: #8C8C8C;
  border: 1rpx solid #E6E2D3;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.5);
  transition: all 0.3s;
}

.privacy-toggle.is-private {
  color: #B22222;
  border-color: rgba(178, 34, 34, 0.2);
  background: rgba(178, 34, 34, 0.05);
}

.answered-seal {
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: rotate(12deg);
  border: 6rpx double rgba(178, 34, 34, 0.4);
  padding: 24rpx 50rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.seal-mark {
  font-family: 'Serif', serif;
  font-size: 44rpx;
  color: #B22222;
  font-weight: bold;
  letter-spacing: 8rpx;
  opacity: 0.7;
}

.seal-date {
  font-size: 20rpx;
  color: #B22222;
  margin-top: 8rpx;
  opacity: 0.5;
  font-style: italic;
}

/* 语气实验室印章样式 */
.ai-eraser-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.ai-eraser-container:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.eraser-ring {
  width: 100rpx;
  height: 100rpx;
  border: 4rpx solid #4A4A4A;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.eraser-ring::after {
  content: '';
  position: absolute;
  width: 86rpx;
  height: 86rpx;
  border: 1rpx solid #4A4A4A;
  border-radius: 50%;
  opacity: 0.3;
}

.eraser-text {
  font-family: 'Serif', serif;
  font-size: 40rpx;
  color: #4A4A4A;
  font-weight: bold;
}

.eraser-hint {
  font-size: 20rpx;
  color: #4A4A4A;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

.seal-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.seal-container:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.seal-ring {
  width: 100rpx;
  height: 100rpx;
  border: 4rpx solid #B22222;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.seal-ring::after {
  content: '';
  position: absolute;
  width: 86rpx;
  height: 86rpx;
  border: 1rpx solid #B22222;
  border-radius: 50%;
  opacity: 0.3;
}

.seal-text {
  font-family: 'Serif', serif;
  font-size: 40rpx;
  color: #B22222;
  font-weight: bold;
}

.seal-hint {
  font-size: 20rpx;
  color: #B22222;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}
