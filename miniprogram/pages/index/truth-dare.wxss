/** truth-dare.wxss - Twos 2.0 Flip Card Animation **/

@import "../../assets/fonts/serif-font.wxss";

.container {
  padding: 40rpx;
  background-color: #FDFCF8;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.paper-title-container {
  margin-top: 20rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.page-title {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: #B22222;
  font-weight: 700;
  letter-spacing: 12rpx;
}

.title-underline {
  width: 100rpx;
  height: 4rpx;
  background: #B22222;
  margin: 16rpx auto;
}

.page-subtitle {
  font-size: 22rpx;
  color: #8C8C8C;
  font-style: italic;
}

/* 卡片区域 */
.cards-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  margin-bottom: 60rpx;
  perspective: 1000px; /* 3D 视角 */
}

.card-wrapper {
  width: 100%;
  height: 320rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.card-wrapper.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  backface-visibility: hidden;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
  border: 1rpx solid rgba(178, 34, 34, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 卡片背面 (初始状态) */
.card-back {
  background: #FFFFFF;
  background-image: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(178,34,34,0.02) 20px, rgba(178,34,34,0.02) 40px);
}

.seal-icon {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #B22222;
  color: #B22222;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  font-family: "Noto Serif SC", serif;
  transform: rotate(-10deg);
  margin-bottom: 20rpx;
}

.tap-hint {
  font-size: 20rpx;
  color: #8C8C8C;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

/* 卡片正面 (翻开后) */
.card-front {
  background: #FFFFFF;
  transform: rotateY(180deg);
}

.card-type-tag {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 700;
}

.card-type-tag.truth { background: rgba(178, 34, 34, 0.05); color: #B22222; }
.card-type-tag.dare { background: rgba(37, 99, 235, 0.05); color: #2563EB; }

.card-content {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #2F2F2F;
  text-align: center;
  line-height: 1.6;
}

.card-footer-logo {
  position: absolute;
  bottom: 24rpx;
  right: 30rpx;
  font-size: 16rpx;
  color: #E0D8C0;
  letter-spacing: 2rpx;
}

/* 按钮区域 */
.actions-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.btn-refresh {
  background: #B22222 !important;
  color: #FFFFFF !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 80rpx;
  font-family: "Noto Serif SC", serif;
}

.action-hint {
  font-size: 20rpx;
  color: #8C8C8C;
}

.footer-seal {
  margin-top: auto;
  margin-bottom: 40rpx;
  padding: 20rpx 60rpx;
  border: 1rpx solid #E0D8C0;
  border-radius: 40rpx;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 24rpx;
  color: #8C8C8C;
}
