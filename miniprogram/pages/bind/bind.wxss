/** bind.wxss - Twos 2.0 Ticket Rebirth **/

@import "../../assets/fonts/serif-font.wxss";

.container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #F8F7F2;
  padding: 40rpx;
}

/* 票据容器 */
.ticket {
  width: 600rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  position: relative;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.1);
  border: 2rpx solid #B22222;
  overflow: visible;
  animation: ticketEntrance 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes ticketEntrance {
  from { opacity: 0; transform: scale(0.8) rotate(-5deg); }
  to { opacity: 1; transform: scale(1) rotate(0deg); }
}

/* 顶部：Logo与标题 */
.ticket-header {
  padding: 40rpx;
  border-bottom: 2rpx dashed #B22222;
  position: relative;
}

.ticket-header::before, .ticket-header::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  width: 40rpx;
  height: 40rpx;
  background: #F8F7F2;
  border-radius: 50%;
  border: 2rpx solid #B22222;
  z-index: 10;
}
.ticket-header::before { left: -22rpx; }
.ticket-header::after { right: -22rpx; }

.logo-text {
  font-family: "Noto Serif SC", serif;
  font-size: 40rpx;
  color: #B22222;
  letter-spacing: 12rpx;
  font-weight: 700;
}

/* 中部：核心内容 */
.ticket-body {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 18rpx;
  color: #8C8C8C;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.value {
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  color: #2F2F2F;
  margin-top: 8rpx;
}

.destination {
  font-size: 48rpx;
  color: #B22222;
}

/* 底部：条形码与按钮 */
.ticket-footer {
  padding: 40rpx;
  background: #FDFCF8;
  border-top: 1rpx solid #E0D8C0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.barcode {
  width: 100%;
  height: 80rpx;
  background-image: repeating-linear-gradient(90deg, #2F2F2F 0, #2F2F2F 2rpx, transparent 2rpx, transparent 8rpx);
  margin-bottom: 40rpx;
  opacity: 0.3;
}

.btn-invite {
  width: 100% !important;
  background: #B22222 !important;
  color: #FFFFFF !important;
  font-family: "Noto Serif SC", serif;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 0;
  box-shadow: 0 10rpx 20rpx rgba(178, 34, 34, 0.2);
  transition: all 0.2s;
}

.btn-invite:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 10rpx rgba(178, 34, 34, 0.1);
}

.hint-text {
  margin-top: 30rpx;
  font-size: 20rpx;
  color: #8C8C8C;
  font-style: italic;
}
