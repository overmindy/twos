/* pages/profile/index.wxss */
.container {
  padding: 40rpx;
  background-color: #FDFCF8;
}

.bond-header {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  width: 100%;
}

.avatar-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.avatar-container.solo {
  justify-content: center;
}

.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.3s ease;
}

.ink-frame-wrapper {
  position: relative;
  width: 130rpx;
  height: 130rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.ink-frame {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border: 4rpx solid #2F2F2F;
  border-radius: 51% 49% 53% 47% / 48% 52% 48% 52%;
  opacity: 0.7;
  pointer-events: none;
}

.avatar-name {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #2F2F2F;
  font-family: "LXGW WenKai", serif;
  letter-spacing: 2rpx;
}

.yuan-si {
  flex: 1;
  max-width: 180rpx;
  margin: 0 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.red-line-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.red-line {
  width: 100%;
  height: 2rpx;
  background-color: #B22222;
  box-shadow: 0 1rpx 4rpx rgba(178, 34, 34, 0.3);
  position: relative;
}

.red-line::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background-color: #B22222;
  border-radius: 50%;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.energy-tag {
  font-size: 18rpx;
  color: #B22222;
  margin-top: 10rpx;
  background-color: rgba(178, 34, 34, 0.05);
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

.atmospheric-preview {
  margin: 60rpx 40rpx 100rpx;
  padding: 40rpx;
  background-color: rgba(0,0,0,0.02);
  border-radius: 8rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mood-quote {
  position: relative;
  margin-bottom: 30rpx;
  padding: 0 40rpx;
  text-align: center;
}

.quote-mark {
  position: absolute;
  top: -20rpx;
  left: 0;
  font-size: 60rpx;
  color: #D1D1D1;
  font-family: serif;
}

.mood-text {
  font-size: 32rpx;
  color: #2F2F2F;
  font-style: italic;
  font-family: "LXGW WenKai", serif;
}

.status-desc {
  font-size: 22rpx;
  color: #8C8C8C;
  letter-spacing: 1rpx;
}

.partner-mood {
  margin-top: 30rpx;
  font-size: 20rpx;
  color: #B22222;
  opacity: 0.8;
  border-top: 1rpx dashed #E0E0E0;
  padding-top: 20rpx;
  width: 100%;
  text-align: center;
}

.seal-wall {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.seal-row {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin: 60rpx 0;
}

.seal-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.seal-label {
  font-size: 20rpx;
  color: #8C8C8C;
  margin-top: 10rpx;
  writing-mode: vertical-rl;
}

.seal-item {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  position: relative;
  transition: transform 0.2s;
}

.seal-item:active {
  transform: scale(0.9);
}

.seal-vermilion {
  border: 4rpx solid #B22222;
  color: #B22222;
  background-color: rgba(178, 34, 34, 0.05);
}

.seal-ink {
  border: 4rpx solid #2F2F2F;
  color: #2F2F2F;
  background-color: rgba(47, 47, 47, 0.05);
}

.seal-content {
  font-size: 60rpx;
  font-family: "LXGW WenKai", serif;
  font-weight: bold;
}

/* 模拟印泥不均匀的效果 */
.seal-item::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, transparent 20%, rgba(255,255,255,0.2) 80%);
  pointer-events: none;
}

.decoration-ink {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  background: radial-gradient(circle, #2F2F2F 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.user-preview {
  margin-top: 100rpx;
  text-align: center;
}

.preview-text {
  font-size: 24rpx;
  color: #8C8C8C;
  font-style: italic;
}

.footer {
  text-align: center;
  margin-top: auto;
  padding-bottom: 40rpx;
  font-size: 20rpx;
  color: #8C8C8C;
}

.paper-texture {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.05;
  pointer-events: none;
  z-index: 999;
}

.stats-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40rpx 0;
  padding: 30rpx;
  background: #F9F8F2;
  border: 1rpx solid #E0D8C0;
  border-radius: 12rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.02);
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.stat-value {
  font-size: 44rpx;
  font-family: serif;
  color: #B22222;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #8C8C8C;
  letter-spacing: 2rpx;
}
/* 灵魂动物选择器 */
.animal-picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  backdrop-filter: blur(4rpx);
}

.animal-picker-content {
  width: 100%;
  background: #FFFFFF;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 40rpx;
  box-sizing: border-box;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.picker-title {
  font-family: "Noto Serif SC", serif;
  font-size: 36rpx;
  color: #2F2F2F;
  letter-spacing: 4rpx;
}

.picker-divider {
  width: 60rpx;
  height: 4rpx;
  background: #B22222;
  margin: 12rpx auto 0;
}

.animal-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.animal-item {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding: 30rpx;
  background: #FDFCF8;
  border: 1rpx solid #F0EAD6;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.animal-item:active {
  background: #FAF9F6;
  transform: scale(0.98);
  border-color: #E0D8C0;
}

.animal-icon {
  width: 100rpx;
  height: 100rpx;
  background: #FFF;
  border-radius: 50%;
  padding: 10rpx;
}

.animal-info {
  display: flex;
  flex-direction: column;
}

.animal-name {
  font-family: "Noto Serif SC", serif;
  font-size: 30rpx;
  color: #2F2F2F;
  font-weight: 600;
}

.animal-label {
  font-size: 22rpx;
  color: #8C8C8C;
  margin-top: 4rpx;
}

/* 勋章样式 */
.badge-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
  justify-content: center;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #FFFFFF;
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid #E0D8C0;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
}

.badge-icon { font-size: 24rpx; }
.badge-name { font-size: 20rpx; color: #B22222; font-family: "Noto Serif SC", serif; }
