/** album.wxss **/
@import "../../../assets/fonts/serif-font.wxss";

.container {
  padding: 0;
  background-color: #FDFCF8;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0D8C0;
}

.title {
  font-family: "Noto Serif SC", serif;
  font-size: 56rpx;
  color: #B22222;
  font-weight: 700;
  letter-spacing: 8rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #8C8C8C;
  margin-top: 10rpx;
  font-style: italic;
}

.album-scroll {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-flow: dense;
  gap: 20rpx;
  padding-bottom: 200rpx;
}

.photo-item {
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
  border: 1rpx solid rgba(178, 34, 34, 0.05);
  transition: transform 0.2s ease;
}

.photo-item:active {
  transform: scale(0.98);
}

.photo-item.large {
  grid-column: span 2;
  grid-row: span 2;
  height: 600rpx;
}

.photo-img {
  width: 100%;
  height: 100%;
  background: #F8F7F2;
}

.photo-desc {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #FFFFFF;
  padding: 20rpx;
  font-size: 22rpx;
  font-family: "Noto Serif SC", serif;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.2;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #8C8C8C;
  font-style: italic;
}

.upload-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: #B22222;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(178, 34, 34, 0.3);
  z-index: 100;
}

.plus {
  color: #FFFFFF;
  font-size: 60rpx;
  margin-top: -6rpx;
}

.footer-seal {
  position: fixed;
  bottom: 40rpx;
  width: 100%;
  text-align: center;
  opacity: 0.4;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 22rpx;
  color: #8C8C8C;
  border: 1rpx solid #E0D8C0;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}
