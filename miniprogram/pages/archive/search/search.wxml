<!-- miniprogram/pages/archive/search/search.wxml -->
<view class="container">
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="输入关键词，找回旧梦..." 
      focus="{{true}}"
      bindinput="onInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <view class="search-btn" bindtap="onSearch">搜寻</view>
  </view>

  <scroll-view scroll-y class="results-scroll">
    <view class="results-list" wx:if="{{results.length > 0}}">
      <view class="result-card" wx:for="{{results}}" wx:key="_id">
        <view class="result-header">
          <text class="result-date">{{item.dateStr}}</text>
          <text class="result-author">{{item.author}}</text>
        </view>
        <text class="result-content">{{item.content}}</text>
      </view>
    </view>

    <view class="empty-state" wx:elif="{{searched && !loading}}">
      <text class="empty-text">未能觅得此番墨迹</text>
    </view>
  </scroll-view>

  <view class="footer-seal" bindtap="goBack">
    <text class="seal-text">返回手札</text>
  </view>
</view>
