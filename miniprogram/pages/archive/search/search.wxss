/** search.wxss **/
@import "../../../assets/fonts/serif-font.wxss";

.container {
  padding: 40rpx;
  background-color: #FDFCF8;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  border-radius: 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  border: 1rpx solid #F0EAD6;
  margin-bottom: 40rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2F2F2F;
}

.search-btn {
  font-family: "Noto Serif SC", serif;
  font-size: 28rpx;
  color: #B22222;
  font-weight: 700;
  padding: 0 20rpx;
}

.results-scroll {
  flex: 1;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding-bottom: 100rpx;
}

.result-card {
  background: #FFFFFF;
  padding: 30rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(178, 34, 34, 0.05);
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02);
}

.result-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #F8F7F2;
  padding-bottom: 10rpx;
}

.result-date { font-size: 20rpx; color: #8C8C8C; font-family: monospace; }
.result-author { font-size: 20rpx; color: #B22222; opacity: 0.6; }

.result-content {
  font-size: 28rpx;
  color: #2F2F2F;
  line-height: 1.6;
}

.empty-state {
  text-align: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #8C8C8C;
  font-style: italic;
}

.footer-seal {
  text-align: center;
  padding: 40rpx 0;
  opacity: 0.4;
}

.seal-text {
  font-family: "Noto Serif SC", serif;
  font-size: 22rpx;
  color: #8C8C8C;
  border: 1rpx solid #E0D8C0;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}
