/**app.wxss**/
page {
  background-color: #FDFCF8;
  background-image: radial-gradient(#E0D8C0 0.5px, transparent 0.5px);
  background-size: 20px 20px; /* 模拟极微弱的纸张网格感，或替换为噪声图 */
  font-family: "LXGW WenKai", "Noto Serif SC", "Source Han Serif SC", "宋体", serif;
  color: #2F2F2F;
  line-height: 1.6;
}

.paper-texture {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.05;
  pointer-events: none;
  z-index: 9999;
}

.serif-text {
  font-family: "LXGW WenKai", "Noto Serif SC", serif;
}

.ink-black { color: #2F2F2F; }
.vermilion-red { color: #B22222; }

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  animation: fadeIn 0.8s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

button {
  background: initial;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}
